          "name": "Redis Don Aveiro"
        }
      }
    },
    {
      "parameters": {
        "resource": "Chatting",
        "operation": "Send Text",
        "session": "=default",
        "chatId": "={{ $('Extrair Dados da Confirmação').item.json.chatId }}",
        "text": "={{ $('AI Agent - Confirmação').item.json.output.replace(/^CONFIRMADO:\\s*/i, '') }}",
        "requestOptions": {}
      },
      "id": "da010007-0007-0007-0007-000000000007",
      "name": "WAHA - Confirmar Presença",
      "type": "n8n-nodes-waha.WAHA",
      "typeVersion": 202411,
      "position": [1780, 100],
      "credentials": {
        "wahaApi": {
          "name": "WAHA account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const dados = $('Extrair Dados da Confirmação').item.json;\nconst phone = String(dados.telefone).replace('@c.us', '');\nconst ids = String(dados.appointment_ids).split(',').map(id => id.trim()).filter(Boolean);\n\nconst results = [];\nfor (const appointment_id of ids) {\n  try {\n    const resp = await $http.request({\n      method: 'POST',\n      url: 'http://bemp-mcp:8000/api/cancel_appointment',\n      headers: { 'Content-Type': 'application/json' },\n      body: JSON.stringify({ appointment_id: Number(appointment_id), phone })\n    });\n    results.push({ id: appointment_id, result: resp });\n  } catch(e) {\n    results.push({ id: appointment_id, error: e.message });\n  }\n}\n\nreturn [{ json: { ...dados, cancelled: results } }];"
      },
      "id": "da010008-0008-0008-0008-000000000008",
      "name": "MCP - Cancelar Agendamentos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
